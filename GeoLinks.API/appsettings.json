{
  "AWS": {
    "Region": "us-east-1"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.ApplicationInsights" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database": "Warning",
        "Microsoft.AspNetCore.Authentication": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/geolinks-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 104857600,
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "connectionString": null
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentUserName" ],
    "Properties": {
      "Application": "GeoLinks.API"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
  "GeoLensContext": "Host=localhost;Port=5432;Database=Vitta;Username=VittaKart;Password=Vitta"
},
  "Jwt": {
    "Key": "D84CF6AACB6BC2C3A4F1E5C3D2B8F7E0",
    "Issuer": "your-issuer",
    "Audience": "http://localhost:19006,exp://192.168.1.11:19000,exp://192.168.1.2:8081,https://localhost:5001,https://127.0.0.1:5001/"
  }
}
